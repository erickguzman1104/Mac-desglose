{
  "expo": {
    "name": "Mac desgloses",
    "slug": "mac-desgloses",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "macdesgloses",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite que Mac Desgloses seleccione el logo de tu empresa."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.macdesgloses.app"
    },
    "ios": {
      "bundleIdentifier": "com.macdesgloses.app",
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
